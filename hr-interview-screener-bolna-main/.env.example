# .env.example
# Copy this file to .env and fill in your details

# Bolna AI Credentials
# Get these from your Bolna Dashboard (https://bolna.dev)
BOLNA_API_KEY=your_bolna_api_key_here
BOLNA_AGENT_ID=your_bolna_agent_id_here

# Server Configuration
PORT=3000

# Ngrok Setup
# The public URL where Bolna sends webhook events (e.g. https://<id>.ngrok.io/api/webhooks/bolna)
PUBLIC_WEBHOOK_URL=your_ngrok_url_here
